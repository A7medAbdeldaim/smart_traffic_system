# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Mode: demo or production
DEMO_MODE=true
MODE=demo

# Detection source: "video" (real YOLO inference on .mp4 feeds) or "demo" (synthetic)
DETECTION_MODE=demo

# YOLO models
YOLO_MODEL_PATH=./models/yolo11n.pt
AMBULANCE_MODEL_PATH=./models/ambulance_detection.pt

# Video feeds (lane → file). Use absolute or project-relative paths.
VIDEO_PATH_N=./video/video_0.mp4
VIDEO_PATH_E=./video/video_1.mp4
VIDEO_PATH_S=./video/video_2.mp4
VIDEO_PATH_W=./video/video_3.mp4
VIDEO_PATH_VIOLATION=./video/violation.mp4

# CPU inference tuning
YOLO_IMG_SIZE=480
YOLO_CONF=0.3
INFERENCE_FPS=3
AMBULANCE_CHECK_EVERY_N_FRAMES=30

# Database Configuration
DATABASE_TYPE=sqlite
DATABASE_PATH=./traffic_data.db

# Simulation Configuration (demo mode)
DEMO_BASE_TRAFFIC=20
DEMO_PEAK_AMPLITUDE=30
DEMO_NOISE_LEVEL=0.2

# Optimizer Configuration
MIN_GREEN_TIME=10
MAX_GREEN_TIME=120
YELLOW_TIME=4
CYCLE_TIME=180

# Emergency Configuration
EMERGENCY_OVERRIDE_DURATION=30
EMERGENCY_RESPONSE_THRESHOLD=2000
