# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Mode: demo or production
DEMO_MODE=true
MODE=demo

# Database Configuration
DATABASE_TYPE=sqlite
DATABASE_PATH=./traffic_data.db

# Simulation Configuration (demo mode)
DEMO_BASE_TRAFFIC=20
DEMO_PEAK_AMPLITUDE=30
DEMO_NOISE_LEVEL=0.2

# Optimizer Configuration
MIN_GREEN_TIME=10
MAX_GREEN_TIME=120
YELLOW_TIME=4
CYCLE_TIME=180

# Emergency Configuration
EMERGENCY_OVERRIDE_DURATION=30
EMERGENCY_RESPONSE_THRESHOLD=2000
